# Base URL of the gatekeeper-mqtt API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public URL of this app — required when running behind a reverse proxy (e.g. Kubernetes ingress)
AUTH_URL=

# next-auth session encryption secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# CSH SSO OIDC client credentials
AUTH_OIDC_ID=
AUTH_OIDC_SECRET=
